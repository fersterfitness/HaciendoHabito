# Supabase
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Feature flags
VITE_FEATURE_NUTRITION=false
VITE_APP_ENV=development

# Formulario público /form → Edge Function `public-intake-form`
# Mismo valor que `INTAKE_SECRET` en Supabase (obligatorio si INTAKE_REQUIRE_SECRET=true)
# VITE_PUBLIC_INTAKE_SECRET=tu-secreto-largo-aqui

# Opcional: fallback si no hay window (SSR). Recovery usa window.location.origin en el navegador.
# VITE_SITE_URL=https://tu-app.vercel.app
# En Supabase → Authentication → URL Configuration, agregar Redirect URLs:
#   http://localhost:5173/**  http://localhost:5174/**  https://tu-app.vercel.app/**

# En Supabase (Edge Functions secrets), además de INTAKE_SECRET:
# INTAKE_REQUIRE_SECRET=true
# CRON_SECRET=...  (para send-appointment-reminders y sync-google-calendar-cancellations)
# Header: x-cron-secret
