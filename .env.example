# Supabase
VITE_SUPABASE_URL=https://xxxx.supabase.co
VITE_SUPABASE_ANON_KEY=eyJhbGc...

# Formulario público /form → Edge Function `public-intake-form`
# Secreto SOLO en Supabase (Edge secrets): INTAKE_SECRET=...
# Si el secreto no va en el bundle del cliente: INTAKE_REQUIRE_SECRET=false
# Legacy (opcional, visible en el JS): VITE_PUBLIC_INTAKE_SECRET=...

# Opcional: fallback si no hay window (SSR). Recovery usa window.location.origin en el navegador.
# VITE_SITE_URL=https://tu-app.vercel.app
# En Supabase → Authentication → URL Configuration, agregar Redirect URLs:
#   http://localhost:5173/**  http://localhost:5174/**  https://tu-app.vercel.app/**

# En Supabase (Edge Functions secrets):
# INTAKE_SECRET=...
# INTAKE_REQUIRE_SECRET=true
# CRON_SECRET=...  (send-appointment-reminders, sync-google-calendar-cancellations; header x-cron-secret)
